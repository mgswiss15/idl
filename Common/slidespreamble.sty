\ProvidesPackage{./../Common/slidespreamble}[2026/03/21, MG]

% packages loaded automatically with beamer
% graphicx, hyperref
% amsmath, amssymb, amsfonts, amstext, amsthm

% font encoding
% \RequirePackage[utf8]{inputenc} % input encoding - not needed, set \documentclass[utf8]{beamer}
% \RequirePackage[T1]{fontenc} % font encoding (T1 works badly without lmodern)
% \RequirePackage{lmodern} % better fonts
\usefonttheme{serif}
\usefonttheme{professionalfonts}
\RequirePackage[T1]{fontenc}
\RequirePackage{kpfonts}
% \usepackage[USenglish]{babel}

% reusable macros
\graphicspath{{Pics/}{../Pics/}{\CommonPath/Pics/}} % multiple paths depending on the location of the main tex file

% math
\RequirePackage{bm} % better bold math symbols
\RequirePackage{wasysym} % even more symbols

% tables
\RequirePackage{booktabs} % better tables
\RequirePackage{multirow} % cells spanning multiple rows
\RequirePackage{multicol} % cells spanning multiple cols

% absolute positioning
% \usepackage[absolute,overlay,showboxes]{textpos}
\usepackage[absolute,overlay]{textpos}
\TPGrid{10}{5}

% THWS color schema
\usepackage{\CommonPath/tango-colors}
\definecolor{thwsorange}{RGB}{255, 106, 0}
\definecolor{thwsblue}{RGB}{22, 60, 105}
\definecolor{thwsgrey}{RGB}{217, 217, 217}
\definecolor{thwspetrol}{RGB}{0, 85, 100} 
\definecolor{lightblue}{RGB}{166,189,219} 
\definecolor{carnelian}{RGB}{179,27,27}

% custom structure formats
\setbeamercolor{titlelike}{fg=thwspetrol}
\setbeamercolor{frametitle}{fg=thwspetrol}
\setbeamerfont{frametitle}{series=\bfseries}
\setbeamercolor{structure}{fg=thwsblue}
\setbeamerfont{structure}{series=\bfseries}
\setbeamercolor{alerted text}{fg=carnelian}
\setbeamercolor{footline}{fg=thwspetrol}
\setbeamerfont{block title}{size=\normalsize, series=\mdseries}
% \addtobeamertemplate{block begin}{}{\vspace{-1em} \setlength{\parindent}{5em}}
\addtobeamertemplate{block begin}{}{\setlength{\parindent}{1em}}
% \hypersetup{colorlinks,urlcolor=thwsblue,linkcolor=thwsblue}
\hypersetup{colorlinks,linkcolor=skyblue2,urlcolor=skyblue2}

% itemization symbol
\setbeamertemplate{itemize items}[circle]

% TOC formatting - cleaner, more consistent with general style
\setbeamertemplate{section in toc}[sections numbered]
\setbeamertemplate{subsection in toc}[subsections numbered]
\setbeamercolor{section number projected}{bg=thwsblue,fg=white}
\setbeamercolor{section in toc}{fg=thwsblue}
\setbeamercolor{subsection in toc}{fg=black}
\setbeamerfont{section in toc}{series=\bfseries}
\setbeamerfont{subsection in toc}{series=\mdseries}

\RequirePackage{tikz}
% \usetikzlibrary{arrows.meta}

\RequirePackage{pgfplots}
\pgfplotsset{compat=1.13}
\pgfplotsset{
    /pgf/number format/.cd,
    use comma=false, 
    1000 sep={}
}

% forloops
\RequirePackage{pgffor}

% frametitle / footline templates
\makeatletter
\setbeamertemplate{frametitle}{
  \begin{textblock}{10}[0,0](0.3, 0.3)
    \color{thwspetrol} \insertframetitle
  \end{textblock}
  \begin{textblock}{1.5}[1,0](10, 0.2)
    \includegraphics[width=2cm]{thws-logo_vert_en_orange-rgb.png}
  \end{textblock}
}
% \setbeamertemplate{footline}[frame number]{}
\providecommand{\coursename}{} % to be used in footnote of every slide - empty default
\setbeamertemplate{footline}{
  \begin{beamercolorbox}[wd=\paperwidth, ht=2.5ex, dp=1ex]{footline}
    \hspace{1em}
    {\scriptsize \color{thwspetrol} M. Gregorová: \coursename}
    \hfill
    {\tiny \color{thwspetrol} \insertframenumber}
    \hspace{1em}
  \end{beamercolorbox}
}
\setbeamertemplate{navigation symbols}{} % supress navigation symbols
\define@key{beamerframe}{c}[true]{% centered page
    \beamer@frametopskip=25pt plus 1fill\relax%
    \beamer@framebottomskip=5pt plus 1fill\relax%
    \beamer@frametopskipautobreak=0pt plus .4\paperheight\relax%
    \beamer@framebottomskipautobreak=0pt plus .6\paperheight\relax%
}
\define@key{beamerframe}{t}[true]{% top aligned page
    \beamer@frametopskip=25pt\relax%
    \beamer@framebottomskip=0pt plus 1fill\relax%
    \beamer@frametopskipautobreak=0pt plus .4\paperheight\relax%
    \beamer@framebottomskipautobreak=0pt plus .6\paperheight\relax%
}
\makeatother

